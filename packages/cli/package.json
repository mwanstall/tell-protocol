{
  "name": "@tell-protocol/cli",
  "version": "0.3.0",
  "description": "Command-line interface for the Tell protocol",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tell": "./dist/tell.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@tell-protocol/core": "workspace:*",
    "@tell-protocol/schema": "workspace:*",
    "commander": "^13.0.0",
    "gradient-string": "^3.0.0",
    "ora": "^9.3.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  }
}
