{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tell-protocol.org/schemas/v0.2/evidence.schema.json",
  "title": "Evidence",
  "description": "A discrete signal that informs whether an assumption is holding or breaking. Immutable once written.",
  "type": "object",
  "required": ["id", "assumption_ids", "source_type", "contributor_id", "signal", "summary", "timestamp", "recorded_at"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "assumption_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "source_type": {
      "type": "string",
      "enum": ["human", "ai_curated", "agent"]
    },
    "contributor_id": { "type": "string", "minLength": 1 },
    "signal": {
      "type": "string",
      "enum": ["supports", "weakens", "neutral"]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "data_ref": { "type": "string", "format": "uri" },
    "timestamp": { "type": "string", "format": "date-time" },
    "recorded_at": { "type": "string", "format": "date-time" },
    "supersedes": { "type": "string" },
    "is_retracted": { "type": "boolean", "default": false },
    "extensions": { "type": "object" }
  },
  "additionalProperties": false
}
