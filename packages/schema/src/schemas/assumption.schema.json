{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tell-protocol.org/schemas/v0.3/assumption.schema.json",
  "title": "Assumption",
  "description": "A condition that must be true for a bet's thesis to hold.",
  "type": "object",
  "required": ["id", "statement", "status", "bet_ids", "evidence", "created_at"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "statement": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["holding", "pressure", "failing", "unknown"]
    },
    "status_source": {
      "type": "string",
      "enum": ["computed", "manual", "override"]
    },
    "evidence_threshold": { "type": "string" },
    "bet_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "owner": { "type": "string" },
    "last_signal_at": { "type": "string", "format": "date-time" },
    "evidence": {
      "type": "array",
      "items": { "$ref": "evidence.schema.json" }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "extensions": { "type": "object" }
  },
  "additionalProperties": false
}
