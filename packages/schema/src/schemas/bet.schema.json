{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tell-protocol.org/schemas/v0.3/bet.schema.json",
  "title": "Bet",
  "description": "A falsifiable hypothesis that the organisation is investing resources to test.",
  "type": "object",
  "required": ["id", "thesis", "status", "assumptions", "created_at", "updated_at"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "thesis": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["active", "paused", "killed", "succeeded"]
    },
    "stage": {
      "type": "string",
      "enum": ["exploring", "validating", "committed", "scaling"]
    },
    "confidence": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "confidence_source": {
      "type": "string",
      "enum": ["computed", "manual", "override"]
    },
    "time_horizon": {
      "type": "object",
      "properties": {
        "start": { "type": "string", "format": "date-time" },
        "target": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "owner": { "type": "string" },
    "resource_allocations": {
      "type": "array",
      "items": { "$ref": "resource-allocation.schema.json" }
    },
    "assumptions": {
      "type": "array",
      "items": { "$ref": "assumption.schema.json" },
      "minItems": 1
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "extensions": { "type": "object" }
  },
  "additionalProperties": false
}
