{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tell-protocol.org/schemas/v0.2/portfolio.schema.json",
  "title": "Portfolio",
  "description": "The top-level container representing an organisation's complete strategic model.",
  "type": "object",
  "required": ["id", "name", "organisation", "version", "created_at", "updated_at", "bets", "connections", "contributors"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "organisation": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "bets": {
      "type": "array",
      "items": { "$ref": "bet.schema.json" }
    },
    "connections": {
      "type": "array",
      "items": { "$ref": "connection.schema.json" }
    },
    "contributors": {
      "type": "array",
      "items": { "$ref": "contributor.schema.json" },
      "minItems": 1
    },
    "scenarios": {
      "type": "array",
      "items": { "$ref": "scenario.schema.json" }
    },
    "experiments": {
      "type": "array",
      "items": { "$ref": "experiment.schema.json" }
    },
    "extensions": { "type": "object" }
  },
  "additionalProperties": false
}
